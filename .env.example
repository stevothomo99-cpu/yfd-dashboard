# YFD Dashboard environment variables.
# Copy to .env.local for local development. Set the live values in
# Vercel → Project Settings → Environment Variables for staging/prod.
# Never commit real secrets to Git.

# ─── Auth ──────────────────────────────────────────────────────────
# Random 32+ char string. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Supabase credentials for user management
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of the deployment. Required in production; auto-detected on Vercel.
# AUTH_URL=https://yfd-dashboard.vercel.app

# ─── XPM / Xero OAuth ─────────────────────────────────────────────
XPM_CLIENT_ID=
XPM_CLIENT_SECRET=
XPM_REFRESH_TOKEN=
XPM_TENANT_ID=
# v3.0 always returns XML regardless of Accept header — only v3.1 supports
# JSON, which lib/xpm.ts relies on. Same OAuth scopes work on both.
XPM_BASE_URL=https://api.xero.com/practicemanager/3.1

# ─── Karbon ───────────────────────────────────────────────────────
KARBON_API_KEY=
# Optional — only needed for Karbon v3 (sends an extra AccessKey header).
KARBON_ACCESS_KEY=
KARBON_BASE_URL=https://api.karbonhq.com/v3
# Karbon v3 has no separate "BAS" resource — /api/karbon/work filters
# /WorkItems by WorkType. Set this to the exact label configured in
# Karbon → Settings → Work Types (e.g. "BAS"). Leave unset to return all
# WorkItems unfiltered.
KARBON_BAS_WORK_TYPE=

# ─── Redis (auto-populated when a Redis integration is attached in Vercel's
# Storage tab — e.g. Upstash). A single connection-string var, not the
# REST API URL/token pair some other Redis add-ons use.
REDIS_URL=

# ─── HubSpot (Phase 2) ────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# ─── Google Cloud (Search Console + GA4) ───────────────────────
# Service account credentials from Google Cloud Console
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
# Private key as base64-encoded string (to avoid newline parsing issues)
# Encode with: cat private-key.txt | base64 -w 0
GOOGLE_PRIVATE_KEY_BASE64=
# GA4 Property IDs (separate for each product)
SITEMARGIN_GA4_PROPERTY_ID=
FOCABLYED_GA4_PROPERTY_ID=
# Found in GA4 Admin > Property Settings
YFD_GA4_PROPERTY_ID=
