# YFD Dashboard environment variables.
# Copy to .env.local for local development. Set the live values in
# Vercel → Project Settings → Environment Variables for staging/prod.
# Never commit real secrets to Git.

# ─── Auth ──────────────────────────────────────────────────────────
# Random 32+ char string. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Single-user credentials (managed internally; rotate by updating Vercel env).
AUTH_USERNAME=
AUTH_PASSWORD=

# Public URL of the deployment. Required in production; auto-detected on Vercel.
# AUTH_URL=https://yfd-dashboard.vercel.app

# ─── XPM / Xero OAuth ─────────────────────────────────────────────
XPM_CLIENT_ID=
XPM_CLIENT_SECRET=
XPM_REFRESH_TOKEN=
XPM_TENANT_ID=
XPM_BASE_URL=https://api.xero.com/practicemanager/3.0

# ─── Karbon ───────────────────────────────────────────────────────
KARBON_API_KEY=
KARBON_BASE_URL=https://app.karbon.com/api/v1

# ─── Vercel KV (auto-populated when KV is attached in the Vercel UI) ──
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── HubSpot (Phase 2) ────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
